# Unity text assets should keep stable line endings in the repository.
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf
*.asmdef text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.controller text eol=lf
*.anim text eol=lf
*.meta text eol=lf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.psd binary
*.wav binary
*.mp3 binary
*.ogg binary
*.fbx binary
*.pdf binary
*.ttf binary
*.otf binary
